{
  "name": "opentack",
  "version": "0.1.0",
  "description": "Local browser-based workspace for opencode",
  "type": "module",
  "bin": {
    "opentack": "./dist/server/cli.js"
  },
  "scripts": {
    "dev": "vite build && electrobun dev",
    "dev:hot": "vite build --watch & (while [ ! -f dist/client/index.html ]; do sleep 0.2; done; electrobun dev)",
    "build": "vite build && electrobun build",
    "build:client": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "@tanstack/react-query": "^5.64.0",
    "@tanstack/react-router": "^1.98.0",
    "chokidar": "^4.0.3",
    "drizzle-orm": "^0.38.2",
    "electrobun": "^1.18.1",
    "fastify": "^5.2.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.30.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
